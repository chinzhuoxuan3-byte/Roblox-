local function getWeaponList()
	local weapons = {}
	local backpack = lp:FindFirstChild("Backpack")
	if backpack then
		for _, v in ipairs(backpack:GetChildren()) do
			if v:IsA("Tool") then
				table.insert(weapons, v.Name)
			end
		end
	end
	return weapons
end

local function getToolByName(name)
	local backpack = lp:FindFirstChild("Backpack")
	if not backpack then return nil end
	for _, v in ipairs(backpack:GetChildren()) do
		if v:IsA("Tool") and v.Name == name then
			return v
		end
	end
	return nil
end

local function equipSlot(slotIndex)
	local slot = slots[slotIndex]
	if not slot.enabled then return end
	
	local char = lp.Character
	if not char then return end
	
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	
	local tool = getToolByName(slot.selectedWeapon)
	if not tool then return end
	
	local equipped = char:FindFirstChildOfClass("Tool")
	if equipped and equipped.Name == tool.Name then
		return
	end
	
	humanoid:EquipTool(tool)
end

local function startSlotThread(slotIndex)
	if slotThreads[slotIndex] then
		task.cancel(slotThreads[slotIndex])
	end
	
	local slot = slots[slotIndex]
	if not slot.enabled then return end
	
	slotThreads[slotIndex] = task.spawn(function()
		while slot.enabled do
			equipSlot(slotIndex)
			task.wait(slot.interval)
		end
	end)
end

