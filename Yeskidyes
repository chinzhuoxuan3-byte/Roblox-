local function BuyItem()
	local hrp = GetHRP()
	if not hrp then Library:Notify("无法获取角色位置", 3) return end
	SaveOriginalPosition()
	local selectedItem = nil
	for _, item in ipairs(ShopItems) do
		if item.name == Config.SelectedItem then selectedItem = item break end
	end
	if not selectedItem then Library:Notify("未找到物品信息", 3) return end
	TeleportToPosition(CFrame.new(selectedItem.position))
	task.wait(0.5)
	if selectedItem.type == "Kanata" then
		local katanaNPC = workspace.ServiceNPCs:FindFirstChild("Katana")
		if katanaNPC then
			local prompt = katanaNPC.HumanoidRootPart:FindFirstChild("KatanaShopPrompt")
			if prompt then
				fireproximityprompt(prompt)
				Library:Notify("正在购买 " .. Config.SelectedItem, 2)
				task.wait(1)
			else
				Library:Notify("未找到交互提示", 3)
			end
		else
			Library:Notify("未找到Katana NPC", 3)
		end
	elseif selectedItem.type == "DarkBlade" then
		local darkBladeNPC = workspace.ServiceNPCs:FindFirstChild("DarkBladeNPC")
		if darkBladeNPC then
			local prompt = darkBladeNPC.HumanoidRootPart:FindFirstChild("DarkBladeShopPrompt")
			if prompt then
				fireproximityprompt(prompt)
				Library:Notify("正在购买 " .. Config.SelectedItem, 2)
				task.wait(1)
			else
				Library:Notify("未找到交互提示", 3)
			end
		else
			Library:Notify("未找到DarkBladeNPC", 3)
		end
	elseif selectedItem.type == "ObservationHaki" then
		local observationNPC = workspace.ServiceNPCs:FindFirstChild("ObservationBuyer")
		if observationNPC then
			local prompt = observationNPC.HumanoidRootPart:FindFirstChild("ObservationHakiPrompt")
			if prompt then
				fireproximityprompt(prompt)
				Library:Notify("正在购买 " .. Config.SelectedItem, 2)
				task.wait(1)
			else
				Library:Notify("未找到交互提示", 3)
			end
		else
			Library:Notify("未找到ObservationBuyer NPC", 3)
		end
	end
	if originalPosition then
		TeleportToPosition(originalPosition)
		Library:Notify("已返回原位", 2)
	end
end

